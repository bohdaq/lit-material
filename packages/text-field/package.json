{
  "name": "@lit-material/text-field",
  "version": "0.0.2",
  "description": "Material Design 3 text field web component (filled + outlined, validation states).",
  "license": "MIT",
  "author": {
    "name": "bohdaq",
    "email": "bohdaq@gmail.com",
    "url": "https://github.com/bohdaq"
  },
  "homepage": "https://github.com/bohdaq/lit-material#readme",
  "bugs": "https://github.com/bohdaq/lit-material/issues",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/bohdaq/lit-material.git",
    "directory": "packages/text-field"
  },
  "keywords": [
    "lit",
    "web-components",
    "lit-material",
    "material-design",
    "material-design-3",
    "text-field",
    "input",
    "form"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "custom-elements.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "web-test-runner && node --import tsx --test src/text-field.ssr.test.ts",
    "analyze": "custom-elements-manifest analyze --litelement --globs \"src/**/*.ts\" --exclude \"src/**/*.test.ts\" --exclude \"src/**/*.ssr.test.ts\""
  },
  "dependencies": {
    "@lit-material/core": "workspace:*",
    "@lit-material/tokens": "workspace:*",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@lit-labs/ssr": "^3.3.1",
    "@open-wc/testing": "^4.0.0",
    "@web/dev-server-esbuild": "^1.0.0",
    "@web/test-runner": "^0.19.0",
    "@web/test-runner-commands": "^0.9.0",
    "@web/test-runner-playwright": "^0.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "customElements": "custom-elements.json"
}
