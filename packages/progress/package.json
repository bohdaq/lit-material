    "type": "git",
    "url": "git+ssh://git@github.com/bohdaq/lit-material.git",
    "directory": "packages/progress"
  },
  "keywords": ["lit", "web-components", "lit-material", "material-design", "material-design-3", "progress-indicator", "linear-progress", "circular-progress", "spinner"],
