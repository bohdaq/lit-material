{
  "name": "lit-material",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/bohdaq/lit-material.git"
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "analyze": "turbo run analyze",
    "dev": "turbo run dev --parallel",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && pnpm analyze && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "eslint": "^10.7.0",
    "eslint-plugin-chai-friendly": "^1.2.1",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.7.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0"
  }
}
