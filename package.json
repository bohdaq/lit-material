{
  "name": "lit-material",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/bohdaq/lit-material.git"
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20"
